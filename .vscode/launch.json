{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Launch Alea Application",
            "request": "launch",
            "mainClass": "io.github.scitia.AleaApplication",
            "projectName": "alea-server",
            "vmArgs": [
                "-Dspring.config.location=D:/Development/ideas/alea/alea/.dev/.config/application.yaml"
            ]
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Spring Boot-AleatoricismApplication<aleatoricism-spring-boot-sample-app>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "io.github.scitia.AleatoricismApplication",
            "projectName": "aleatoricism-spring-boot-sample-app",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}